# haxvibe — environment variables template
# Copy this file to .env.local and fill in the secrets.
# NEVER commit .env.local or any file containing real secrets.

# =========================================================================
# Core
# =========================================================================
NODE_ENV=development
LOG_LEVEL=debug
CURRENT_TOS_VERSION=2026-04-01

# =========================================================================
# Supabase
# =========================================================================
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =========================================================================
# Database (direct connection for migrations, admin queries)
# =========================================================================
DATABASE_URL=
DATABASE_URL_POOLED=

# =========================================================================
# Gemini (LLM provider for report generation)
# =========================================================================
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-pro

# =========================================================================
# Redis (local Docker Compose in dev)
# =========================================================================
REDIS_URL=redis://localhost:6379

# =========================================================================
# API server
# =========================================================================
API_HOST=0.0.0.0
API_PORT=4000
API_CORS_ORIGINS=http://localhost:3000

# =========================================================================
# Web
# =========================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# =========================================================================
# Scanner
# =========================================================================
NUCLEI_IMAGE=projectdiscovery/nuclei:v3
NUCLEI_NETWORK=nuclei-outbound
NUCLEI_MAX_DURATION_MS=1800000
NUCLEI_RATE_LIMIT=100
NUCLEI_CONCURRENCY=10
SCANNER_TMP_DIR=/tmp/scanner

# =========================================================================
# BullMQ
# =========================================================================
BULL_CONCURRENCY=3
BULL_RATE_LIMIT_MAX=10
BULL_RATE_LIMIT_DURATION_MS=60000

# =========================================================================
# Scanner Mode
# 'docker'   — Docker-in-Docker (requires Docker socket, nuclei-outbound network)
# 'cloudrun' — HTTP call to Cloud Run nuclei-runner service (no Docker needed)
# =========================================================================
SCANNER_MODE=docker

# Cloud Run settings (required when SCANNER_MODE=cloudrun)
# CLOUDRUN_SCANNER_URL=https://nuclei-runner-xxxx-ew.a.run.app
# CLOUDRUN_SCANNER_AUTH_TOKEN=<min 20 chars shared secret>
# CLOUDRUN_SCANNER_TIMEOUT_MS=660000
# CLOUDRUN_CALLBACK_URL=http://localhost:4000

# Scanner auth token for API internal progress callback (must match CLOUDRUN_SCANNER_AUTH_TOKEN)
# SCANNER_AUTH_TOKEN=<same as CLOUDRUN_SCANNER_AUTH_TOKEN>
